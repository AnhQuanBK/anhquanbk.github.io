    "categories": [
        "games"
    ],
    "prefer_related_applications": false,
    "dir": "auto",
    "display_override": [
        "window-controls-overlay"
    ],
    "_msstart": {
        "leaderboards": {
            "default": {
                "score_type": "Numeric",
                "score_order_by": "Desc"
            }
        }
    }
